# gjc bridge dev env (EXAMPLE). Copy to ops/web-proxy/bridge.env (gitignored), fill in,
# then:  set -a; . ops/web-proxy/bridge.env; set +a; gjc --mode bridge
#
# Generate a token:  openssl rand -hex 32
GJC_BRIDGE_TOKEN=replace-with-output-of-openssl-rand-hex-32
GJC_BRIDGE_HOST=127.0.0.1
GJC_BRIDGE_PORT=4077

# Enables the session endpoints. Requires the opt-in patch in
# patches/gjc-bridge-endpoints.md applied to the installed @gajae-code/coding-agent;
# without it the bridge stays fail-closed and every /v1/sessions/* route is disabled.
GJC_BRIDGE_ENDPOINTS=all
GJC_BRIDGE_SCOPES=prompt,control,bash,export,session,model,message:read,host_tools,host_uri,admin

# Self-signed cert for the bridge's own TLS (Caddy connects with tls_insecure_skip_verify):
#   openssl req -x509 -newkey rsa:2048 -nodes \
#     -keyout ops/web-proxy/.certs/bridge-key.pem -out ops/web-proxy/.certs/bridge-cert.pem \
#     -days 825 -subj "/CN=localhost" -addext "subjectAltName=DNS:localhost,IP:127.0.0.1"
GJC_BRIDGE_TLS_CERT=ops/web-proxy/.certs/bridge-cert.pem
GJC_BRIDGE_TLS_KEY=ops/web-proxy/.certs/bridge-key.pem
